# maui_write_safety.rules
# Technology: maui | Capability: write

rule maui-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_maui_PATTERN"
  MESSAGE "Blocked an unsafe pattern in maui. Use the recommended best practices for 2025/2026."
}

rule maui-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_maui_API"
  MESSAGE "You are using an outdated API for maui. Please upgrade to the newer API."
}
